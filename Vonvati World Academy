<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vonvati World Academy — Escuela de Baile en Guadalajara</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #fafafa;
    --red: #c8102e;
    --red-dark: #a00d24;
    --gray-100: #f2f2f2;
    --gray-200: #e0e0e0;
    --gray-400: #999;
    --gray-600: #555;
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'DM Sans', sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--white);
    color: var(--black);
    overflow-x: hidden;
  }

  /* ─── NAVBAR ─── */
  nav {
    position: fixed; top: 0; left: 0; width: 100%; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 5%;
    background: rgba(10,10,10,0.96);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-logo {
    font-family: var(--serif);
    font-size: 1.45rem;
    font-weight: 600;
    color: var(--white);
    letter-spacing: 0.05em;
    text-decoration: none;
  }
  .nav-logo span { color: var(--red); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a {
    color: rgba(255,255,255,0.65);
    text-decoration: none;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color .25s;
  }
  .nav-links a:hover { color: var(--white); }
  .nav-cta {
    background: var(--red);
    color: var(--white) !important;
    padding: 9px 22px;
    border-radius: 2px;
    font-weight: 500;
  }
  .nav-cta:hover { background: var(--red-dark) !important; color: var(--white) !important; }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; }
  .hamburger span { width: 24px; height: 1.5px; background: var(--white); display: block; }

  /* ─── HERO ─── */
  #hero {
    min-height: 100vh;
    background: var(--black);
    display: flex; align-items: center;
    position: relative;
    overflow: hidden;
    padding: 120px 5% 80px;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 70% at 80% 50%, rgba(200,16,46,0.12) 0%, transparent 70%);
  }
  .hero-lines {
    position: absolute; inset: 0; pointer-events: none; opacity: 0.04;
    background-image: repeating-linear-gradient(0deg, transparent, transparent 79px, rgba(255,255,255,1) 80px);
  }
  .hero-content { position: relative; z-index: 2; max-width: 680px; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--red); font-weight: 500; margin-bottom: 28px;
    opacity: 0; animation: fadeUp .8s .2s forwards;
  }
  .hero-eyebrow::before {
    content: ''; width: 28px; height: 1px; background: var(--red);
  }
  .hero-title {
    font-family: var(--serif);
    font-size: clamp(3.2rem, 7vw, 6rem);
    line-height: 1.04;
    color: var(--white);
    font-weight: 300;
    margin-bottom: 10px;
    opacity: 0; animation: fadeUp .9s .35s forwards;
  }
  .hero-title em { font-style: italic; color: var(--red); }
  .hero-title .line2 {
    display: block;
    font-weight: 600;
    -webkit-text-stroke: 0px;
  }
  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.52);
    max-width: 480px;
    margin-top: 28px;
    margin-bottom: 44px;
    opacity: 0; animation: fadeUp .9s .5s forwards;
  }
  .hero-actions {
    display: flex; gap: 16px; flex-wrap: wrap;
    opacity: 0; animation: fadeUp .9s .65s forwards;
  }
  .btn-primary {
    background: var(--red);
    color: var(--white);
    padding: 16px 36px;
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    font-weight: 500;
    transition: background .25s, transform .2s;
  }
  .btn-primary:hover { background: var(--red-dark); transform: translateY(-2px); }
  .btn-outline {
    background: transparent;
    color: rgba(255,255,255,0.7);
    padding: 15px 32px;
    font-family: var(--sans);
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 2px;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    font-weight: 400;
    transition: border-color .25s, color .25s;
  }
  .btn-outline:hover { border-color: rgba(255,255,255,0.6); color: var(--white); }
  .hero-stats {
    position: absolute; right: 5%; bottom: 60px;
    display: flex; gap: 48px;
    opacity: 0; animation: fadeUp .9s .8s forwards;
  }
  .stat { text-align: right; }
  .stat-num {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1;
  }
  .stat-num span { color: var(--red); }
  .stat-label { font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-top: 4px; }

  /* ─── SECTION BASE ─── */
  section { padding: 100px 5%; }
  .section-tag {
    font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--red); display: flex; align-items: center; gap: 10px;
    margin-bottom: 18px; font-weight: 500;
  }
  .section-tag::before { content: ''; width: 24px; height: 1px; background: var(--red); }
  .section-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: 300;
    line-height: 1.1;
    margin-bottom: 20px;
  }
  .section-title strong { font-weight: 600; }
  .divider { width: 48px; height: 2px; background: var(--red); margin: 28px 0; }

  /* ─── SOBRE NOSOTROS ─── */
  #about { background: var(--white); }
  .about-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
    align-items: center; max-width: 1200px; margin: 0 auto;
  }
  .about-text p {
    font-size: 1rem; line-height: 1.8; color: var(--gray-600);
    margin-bottom: 20px;
  }
  .about-visual {
    position: relative;
  }
  .about-card {
    background: var(--black);
    color: var(--white);
    padding: 52px 44px;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }
  .about-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 4px; height: 100%; background: var(--red);
  }
  .about-card-quote {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-style: italic;
    font-weight: 300;
    line-height: 1.4;
    color: rgba(255,255,255,0.9);
    margin-bottom: 28px;
  }
  .about-pillars {
    display: flex; flex-direction: column; gap: 16px; margin-top: 40px;
  }
  .pillar {
    display: flex; align-items: center; gap: 14px;
    font-size: 0.88rem; color: var(--gray-600);
  }
  .pillar-dot { width: 6px; height: 6px; background: var(--red); border-radius: 50%; flex-shrink: 0; }

  /* ─── CLASES ─── */
  #classes { background: var(--black); }
  #classes .section-title { color: var(--white); }
  #classes .section-tag { margin-left: 0; }
  .classes-intro { color: rgba(255,255,255,0.5); max-width: 480px; margin-bottom: 56px; line-height: 1.7; }
  .classes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2px;
    max-width: 1200px; margin: 0 auto;
  }
  .class-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 36px 28px;
    transition: background .3s, border-color .3s;
    cursor: default;
    position: relative;
    overflow: hidden;
  }
  .class-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0;
    width: 0; height: 2px; background: var(--red);
    transition: width .4s;
  }
  .class-card:hover { background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); }
  .class-card:hover::after { width: 100%; }
  .class-icon { font-size: 1.8rem; margin-bottom: 16px; }
  .class-name {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 8px;
  }
  .class-desc { font-size: 0.82rem; color: rgba(255,255,255,0.4); line-height: 1.6; }
  .class-badge {
    display: inline-block; margin-top: 12px;
    font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--red); border: 1px solid rgba(200,16,46,0.4); padding: 3px 8px; border-radius: 2px;
  }

  /* ─── PRECIOS ─── */
  #pricing { background: var(--gray-100); }
  .pricing-header { max-width: 600px; margin-bottom: 60px; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    max-width: 1200px;
  }
  .price-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: 4px;
    padding: 36px 30px;
    position: relative;
    transition: box-shadow .3s, transform .3s;
  }
  .price-card:hover { box-shadow: 0 16px 48px rgba(0,0,0,0.1); transform: translateY(-4px); }
  .price-card.featured {
    background: var(--black);
    border-color: var(--black);
    color: var(--white);
  }
  .price-card.featured .price-name { color: rgba(255,255,255,0.5); }
  .price-card.featured .price-amount { color: var(--white); }
  .price-card.featured .price-desc { color: rgba(255,255,255,0.5); }
  .price-card.featured .price-feature { color: rgba(255,255,255,0.7); border-color: rgba(255,255,255,0.1); }
  .featured-badge {
    position: absolute; top: -1px; right: 24px;
    background: var(--red); color: var(--white);
    font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 5px 12px; border-radius: 0 0 4px 4px; font-weight: 500;
  }
  .price-name { font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gray-400); margin-bottom: 16px; }
  .price-amount {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 600;
    color: var(--black);
    line-height: 1;
    margin-bottom: 6px;
  }
  .price-amount sup { font-size: 1.2rem; vertical-align: super; }
  .price-period { font-size: 0.78rem; color: var(--gray-400); margin-bottom: 20px; }
  .price-divider { height: 1px; background: var(--gray-200); margin: 20px 0; }
  .price-card.featured .price-divider { background: rgba(255,255,255,0.1); }
  .price-features { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
  .price-feature {
    font-size: 0.85rem; color: var(--gray-600);
    display: flex; align-items: flex-start; gap: 10px;
    padding-bottom: 10px; border-bottom: 1px solid var(--gray-100);
  }
  .price-feature:last-child { border: none; padding: 0; }
  .check { color: var(--red); font-size: 0.9rem; flex-shrink: 0; margin-top: 1px; }
  .price-cta {
    display: block; text-align: center;
    background: var(--black); color: var(--white);
    padding: 14px; border-radius: 2px;
    font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase;
    text-decoration: none; font-weight: 500;
    transition: background .25s;
  }
  .price-cta:hover { background: #222; }
  .price-card.featured .price-cta { background: var(--red); }
  .price-card.featured .price-cta:hover { background: var(--red-dark); }
  .pricing-note {
    margin-top: 48px; text-align: center;
    font-size: 0.85rem; color: var(--gray-400);
    max-width: 600px; margin-left: auto; margin-right: auto;
    margin-top: 48px;
  }

  /* ─── CÓMO FUNCIONA ─── */
  #how { background: var(--white); }
  .how-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; max-width: 1100px; }
  .how-card {
    padding: 40px;
    border: 1px solid var(--gray-200);
    border-radius: 4px;
    position: relative;
  }
  .how-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 100%; height: 3px; background: var(--black);
    border-radius: 4px 4px 0 0;
  }
  .how-number {
    font-family: var(--serif);
    font-size: 4rem;
    font-weight: 300;
    color: var(--gray-200);
    line-height: 1;
    margin-bottom: 12px;
  }
  .how-title { font-size: 1.15rem; font-weight: 500; margin-bottom: 14px; }
  .how-text { font-size: 0.9rem; color: var(--gray-600); line-height: 1.7; }
  .how-list { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; }
  .how-item { display: flex; gap: 10px; font-size: 0.85rem; color: var(--gray-600); }
  .how-item::before { content: '—'; color: var(--red); flex-shrink: 0; }

  /* ─── EXPERIENCIA ─── */
  #experience { background: var(--black); }
  #experience .section-title { color: var(--white); }
  .exp-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; max-width: 1100px;
    margin-top: 56px;
  }
  .exp-card {
    padding: 44px 36px;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.02);
  }
  .exp-icon { font-size: 2rem; margin-bottom: 20px; }
  .exp-title {
    font-family: var(--serif);
    font-size: 1.4rem;
    color: var(--white);
    margin-bottom: 12px;
  }
  .exp-text { font-size: 0.85rem; color: rgba(255,255,255,0.45); line-height: 1.7; }

  /* ─── RESEÑAS ─── */
  #reviews { background: var(--gray-100); }
  .stars { color: #f4b400; font-size: 1rem; margin-bottom: 8px; letter-spacing: 2px; }
  .reviews-header { display: flex; align-items: flex-end; gap: 24px; margin-bottom: 56px; flex-wrap: wrap; }
  .overall-score {
    font-family: var(--serif);
    font-size: 5rem;
    font-weight: 600;
    line-height: 1;
    color: var(--black);
  }
  .reviews-meta { padding-bottom: 12px; }
  .reviews-meta .stars { font-size: 1.2rem; }
  .reviews-meta p { font-size: 0.82rem; color: var(--gray-400); margin-top: 6px; }
  .reviews-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px; max-width: 1100px;
  }
  .review-card {
    background: var(--white);
    border-radius: 4px;
    padding: 28px;
    border: 1px solid var(--gray-200);
  }
  .review-header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
  .review-avatar {
    width: 42px; height: 42px; border-radius: 50%;
    background: var(--black); color: var(--white);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--serif); font-size: 1.1rem; font-weight: 600;
    flex-shrink: 0;
  }
  .review-name { font-weight: 500; font-size: 0.9rem; }
  .review-date { font-size: 0.75rem; color: var(--gray-400); margin-top: 2px; }
  .review-text { font-size: 0.87rem; color: var(--gray-600); line-height: 1.7; }

  /* ─── TESTIMONIOS ─── */
  #testimonials { background: var(--white); }
  .testimonials-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 32px; max-width: 1100px; margin-top: 56px;
  }
  .testimonial {
    padding: 40px;
    border-left: 3px solid var(--red);
    background: var(--gray-100);
    border-radius: 0 4px 4px 0;
  }
  .testimonial-quote {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--black);
    margin-bottom: 24px;
  }
  .testimonial-author { display: flex; align-items: center; gap: 12px; }
  .testimonial-avatar {
    width: 38px; height: 38px; border-radius: 50%;
    background: var(--red); color: var(--white);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.9rem; font-weight: 600; flex-shrink: 0;
  }
  .testimonial-name { font-weight: 500; font-size: 0.88rem; }
  .testimonial-detail { font-size: 0.75rem; color: var(--gray-400); margin-top: 2px; }

  /* ─── MAPA ─── */
  #location { background: var(--black); padding-bottom: 0; }
  #location .section-title { color: var(--white); }
  .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .location-info { padding-bottom: 100px; }
  .location-detail {
    display: flex; gap: 14px;
    margin-bottom: 28px;
  }
  .location-icon { color: var(--red); font-size: 1.1rem; margin-top: 2px; flex-shrink: 0; }
  .location-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 4px; }
  .location-value { font-size: 0.95rem; color: rgba(255,255,255,0.8); line-height: 1.5; }
  .map-wrapper {
    width: 100%; height: 460px;
    filter: grayscale(30%) contrast(1.1);
    border-radius: 4px 4px 0 0;
    overflow: hidden;
    align-self: end;
  }
  .map-wrapper iframe { width: 100%; height: 100%; border: 0; display: block; }

  /* ─── CTA BAND ─── */
  #cta {
    background: var(--red);
    padding: 80px 5%;
    text-align: center;
  }
  #cta h2 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--white);
    font-weight: 300;
    margin-bottom: 10px;
  }
  #cta h2 strong { font-weight: 600; }
  #cta p { color: rgba(255,255,255,0.75); margin-bottom: 36px; font-size: 1rem; }
  #cta .btn-white {
    background: var(--white);
    color: var(--red);
    padding: 16px 44px;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: none; border-radius: 2px;
    cursor: pointer;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    transition: transform .2s, box-shadow .2s;
  }
  #cta .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0,0,0,0.25); }

  /* ─── FORMULARIO ─── */
  #form-section { background: var(--white); }
  .form-wrapper {
    display: grid; grid-template-columns: 1fr 1fr; gap: 80px;
    max-width: 1100px; align-items: center;
  }
  .form-intro p { font-size: 0.95rem; color: var(--gray-600); line-height: 1.8; max-width: 400px; }
  .contact-form { display: flex; flex-direction: column; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-group label { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gray-400); }
  .form-group input, .form-group select {
    border: 1px solid var(--gray-200);
    border-radius: 2px;
    padding: 13px 16px;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--black);
    background: var(--white);
    transition: border-color .25s;
    outline: none;
    -webkit-appearance: none;
  }
  .form-group input:focus, .form-group select:focus { border-color: var(--black); }
  .form-submit {
    background: var(--black);
    color: var(--white);
    padding: 15px;
    border: none; border-radius: 2px; cursor: pointer;
    font-family: var(--sans);
    font-size: 0.82rem; letter-spacing: 0.12em; text-transform: uppercase;
    font-weight: 500; margin-top: 8px;
    transition: background .25s;
  }
  .form-submit:hover { background: var(--red); }
  .payment-badges {
    display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px;
  }
  .payment-badge {
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    padding: 8px 16px; border-radius: 2px;
    font-size: 0.8rem; color: var(--gray-600);
    display: flex; align-items: center; gap: 6px;
  }

  /* ─── FOOTER ─── */
  footer {
    background: var(--black);
    padding: 60px 5% 36px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr;
    gap: 60px; max-width: 1100px; margin-bottom: 48px;
  }
  .footer-brand {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--white);
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 14px;
  }
  .footer-brand span { color: var(--red); }
  .footer-tagline { font-size: 0.85rem; color: rgba(255,255,255,0.35); max-width: 280px; line-height: 1.6; }
  .footer-col h4 {
